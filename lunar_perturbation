< !DOCTYPE html >
  <html lang="en">
    <head>
      <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <title>Tidal Locking Visualizer</title>
          <script src="https://cdn.tailwindcss.com"></script>
          <style>
            body {
              font - family: 'Inter', sans-serif;
            background-color: #0f172a; /* tailwind slate-900 */
            color: #f8fafc; /* tailwind slate-50 */
            margin: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }
            #canvas-container {
              flex - grow: 1;
            position: relative;
            width: 100%;
            height: 100%;
        }
            canvas {
              display: block;
            width: 100%;
            height: 100%;
        }
            .controls-panel {
              position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(30, 41, 59, 0.85); /* slate-800 with opacity */
            backdrop-filter: blur(8px);
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            gap: 2rem;
            align-items: center;
            width: 90%;
            max-width: 800px;
            z-index: 10;
        }
            .control-group {
              display: flex;
            flex-direction: column;
            flex: 1;
        }
            label {
              font - size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: #cbd5e1; /* slate-300 */
        }
            input[type="range"] {
              width: 100%;
            accent-color: #3b82f6; /* blue-500 */
        }
            button {
              background - color: #3b82f6;
            color: white;
            border: none;
            padding: 0.5rem 1.25rem;
            border-radius: 0.5rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }
            button:hover {
              background - color: #2563eb;
        }
            .info-overlay {
              position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(30, 41, 59, 0.7);
            padding: 1rem;
            border-radius: 0.75rem;
            font-size: 0.875rem;
            pointer-events: none;
        }
          </style>
        </head>
        <body>

          <div id="canvas-container">
            <canvas id="simCanvas"></canvas>

            <div class="info-overlay">
              <h2 class="text-xl font-bold mb-2 text-blue-400">Tidal Locking</h2>
              <div id="stats">
                <p>Orbital Rate: <span id="valOrbit">0</span></p>
                <p>Spin Rate: <span id="valSpin">0</span></p>
                <p>Phase Lag: <span id="valLag">0</span>°</p>
                <p>Status: <span id="valStatus" class="font-bold text-yellow-400">Oscillating</span></p>
              </div>
            </div>

            <div class="controls-panel">
              <div class="control-group">
                <label for="dissipationSlider">Tidal Dissipation (Friction)</label>
                <input type="range" id="dissipationSlider" min="0" max="100" value="30">
              </div>
              <div class="control-group">
                <label for="initialSpinSlider">Kick (Add Spin)</label>
                <input type="range" id="initialSpinSlider" min="-50" max="50" value="0">
              </div>
              <div class="control-group">
                <label for="speedSlider">Simulation Speed</label>
                <input type="range" id="speedSlider" min="0" max="200" value="100">
              </div>
              <button id="resetBtn">Reset Sim</button>
            </div>
          </div>

          <script>
            const canvas = document.getElementById('simCanvas');
            const ctx = canvas.getContext('2d');

            // UI Elements
            const dissipationSlider = document.getElementById('dissipationSlider');
            const initialSpinSlider = document.getElementById('initialSpinSlider');
            const speedSlider = document.getElementById('speedSlider');
            const resetBtn = document.getElementById('resetBtn');
            const valOrbit = document.getElementById('valOrbit');
            const valSpin = document.getElementById('valSpin');
            const valLag = document.getElementById('valLag');
            const valStatus = document.getElementById('valStatus');

            let width, height;

            // Simulation Parameters
            const G = 1; // Gravitational constant equivalent
            const massPlanet = 10000;
            const radiusPlanet = 50;

            const massMoon = 100;
            const radiusMoonEquatorial = 25; // Stretched axis
            const radiusMoonPolar = 18;      // Compressed axis
            const orbitRadius = 250;

            // State variables
            let time = 0;
            // Moon orbital angle (around planet)
            let thetaOrbit = 0;
            // Moon rotation angle (around its own axis) relative to a fixed star
            let thetaSpin = 0;

            // Velocities
            // Keplerian orbital velocity roughly: sqrt(G*M/r)
            const omegaOrbit = Math.sqrt(G * massPlanet / Math.pow(orbitRadius, 1));
            // Start with a spin slightly faster than orbit to show the pendulum oscillation
            let omegaSpin = omegaOrbit * 1.05;

            // Physics tuning
            let dissipationFactor = 0.002; // How fast the energy dissipates
            const bulgeTorqueStrength = 0.005; // Strength of the restoring force

            let timeScale = 1.0;
            const baseTimeStep = 1.0; // The standard physics step size

            function resize() {
              width = canvas.clientWidth;
            height = canvas.clientHeight;
            canvas.width = width;
            canvas.height = height;
        }

            window.addEventListener('resize', resize);
            resize();

        dissipationSlider.addEventListener('input', (e) => {
              // Map 0-100 to a reasonable dissipation range
              dissipationFactor = e.target.value / 10000; 
        });

        initialSpinSlider.addEventListener('input', (e) => {
              // Let user add a momentary kick to the spin
              let kick = parseInt(e.target.value);
            if (kick !== 0) {
              omegaSpin += kick * 0.001;
            e.target.value = 0; // reset slider to center
             }
        });

        speedSlider.addEventListener('input', (e) => {
              timeScale = e.target.value / 100;
        });

        resetBtn.addEventListener('click', () => {
              thetaOrbit = 0;
            thetaSpin = 0;
            omegaSpin = omegaOrbit * 1.05;
            dissipationSlider.value = 30;
            dissipationFactor = 0.003;
            speedSlider.value = 100;
            timeScale = 1.0;
        });

            function drawArrow(ctx, fromx, fromy, tox, toy, arrowWidth, color){
            //variables to be used when creating the arrow
            var headlen = 10;
            var angle = Math.atan2(toy-fromy,tox-fromx);

            ctx.save();
            ctx.strokeStyle = color;

            //starting path of the arrow from the start square to the end square
            //and drawing the stroke
            ctx.beginPath();
            ctx.moveTo(fromx, fromy);
            ctx.lineTo(tox, toy);
            ctx.lineWidth = arrowWidth;
            ctx.stroke();

            //starting a new path from the head of the arrow to one of the sides of
            //the point
            ctx.beginPath();
            ctx.moveTo(tox, toy);
            ctx.lineTo(tox-headlen*Math.cos(angle-Math.PI/7),
            toy-headlen*Math.sin(angle-Math.PI/7));

            //path from the side point of the arrow, to the other side point
            ctx.lineTo(tox-headlen*Math.cos(angle+Math.PI/7),
            toy-headlen*Math.sin(angle+Math.PI/7));

            //path from the side point back to the tip of the arrow, and then
            //again to the opposite side point
            ctx.lineTo(tox, toy);
            ctx.lineTo(tox-headlen*Math.cos(angle-Math.PI/7),
            toy-headlen*Math.sin(angle-Math.PI/7));

            //draws the paths created above
            ctx.fillStyle = color;
            ctx.fill();
            ctx.restore();
        }

            function updatePhysicsStep(dt) {
              // 1. Update orbital position
              thetaOrbit += omegaOrbit * dt;
            // Keep angle between 0 and 2PI
            thetaOrbit = thetaOrbit % (Math.PI * 2);

            // 2. Calculate the "Geometric Misalignment" or Phase Lag
            let phaseLag = thetaSpin - thetaOrbit;

            // Normalize phase lag to be between -PI and PI
            while (phaseLag > Math.PI) phaseLag -= Math.PI * 2;
            while (phaseLag < -Math.PI) phaseLag += Math.PI * 2;

            // 3. Apply Restoring Torque
            let torque = -bulgeTorqueStrength * Math.sin(2 * phaseLag);

            // 4. Apply Tidal Dissipation (Internal Friction)
            let relativeSpin = omegaSpin - omegaOrbit;
            let friction = -dissipationFactor * relativeSpin;

            // Update angular velocity based on forces
            omegaSpin += (torque + friction) * dt;

            // Update spin position
            thetaSpin += omegaSpin * dt;
            thetaSpin = thetaSpin % (Math.PI * 2);

            return {phaseLag, torque};
        }

            function updateSimulation() {
              let steps = Math.max(1, Math.floor(timeScale));
            let dt = (timeScale / steps) * baseTimeStep; // Distribute the time scale across steps

            let lastPhysicsData;

            // Run physics multiple times per visual frame if sped up
            for(let i=0; i < steps; i++) {
              lastPhysicsData = updatePhysicsStep(dt);
            }
            return lastPhysicsData;
        }

            function draw(physicsData) {
              ctx.clearRect(0, 0, width, height);

            const centerX = width / 2;
            const centerY = height / 2;

            // Draw Planet
            ctx.beginPath();
            ctx.arc(centerX, centerY, radiusPlanet, 0, Math.PI * 2);
            // Gradient for planet
            let pltGrd = ctx.createRadialGradient(centerX-15, centerY-15, 5, centerX, centerY, radiusPlanet);
            pltGrd.addColorStop(0, '#60a5fa'); // blue-400
            pltGrd.addColorStop(1, '#1e3a8a'); // blue-900
            ctx.fillStyle = pltGrd;
            ctx.fill();

            // Draw Planet Glow
            ctx.shadowBlur = 20;
            ctx.shadowColor = 'rgba(96, 165, 250, 0.5)';
            ctx.stroke();
            ctx.shadowBlur = 0; // reset

            // Calculate Moon Position
            const moonX = centerX + orbitRadius * Math.cos(thetaOrbit);
            const moonY = centerY + orbitRadius * Math.sin(thetaOrbit);

            // Draw Orbit Path
            ctx.beginPath();
            ctx.arc(centerX, centerY, orbitRadius, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
            ctx.lineWidth = 1;
            ctx.stroke();

            // Draw Center Line (Planet to Moon)
            ctx.beginPath();
            ctx.moveTo(centerX, centerY);
            ctx.lineTo(moonX, moonY);
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';
            ctx.setLineDash([5, 5]);
            ctx.stroke();
            ctx.setLineDash([]); // reset

            // --- Draw Moon ---
            ctx.save();
            ctx.translate(moonX, moonY);
            ctx.rotate(thetaSpin); // Rotate moon around its own center

            // Draw the oval moon
            ctx.beginPath();
            ctx.ellipse(0, 0, radiusMoonEquatorial, radiusMoonPolar, 0, 0, 2 * Math.PI);

            let moonGrd = ctx.createRadialGradient(0, 0, 5, 0, 0, radiusMoonEquatorial);
            moonGrd.addColorStop(0, '#94a3b8'); // slate-400
            moonGrd.addColorStop(1, '#334155'); // slate-700
            ctx.fillStyle = moonGrd;
            ctx.fill();
            ctx.lineWidth = 2;
            ctx.strokeStyle = '#cbd5e1';
            ctx.stroke();

            // Draw a marker on the moon to show rotation clearly
            ctx.beginPath();
            ctx.arc(radiusMoonEquatorial - 6, 0, 4, 0, Math.PI * 2);
            ctx.fillStyle = '#ef4444'; // red marker to show the "near side"
            ctx.fill();

            // Draw axis line through moon
            ctx.beginPath();
            ctx.moveTo(-radiusMoonEquatorial - 10, 0);
            ctx.lineTo(radiusMoonEquatorial + 10, 0);
            ctx.strokeStyle = 'rgba(239, 68, 68, 0.5)'; // red dashed line
            ctx.setLineDash([2, 4]);
            ctx.stroke();
            ctx.setLineDash([]);

            ctx.restore();

            // --- Draw Forces (Visualizing the pull on the bulges) ---
            // The near bulge is pulled stronger than the far bulge.

            // Find positions of the two bulges in global coordinates
            const bulgeNearX = moonX + radiusMoonEquatorial * Math.cos(thetaSpin);
            const bulgeNearY = moonY + radiusMoonEquatorial * Math.sin(thetaSpin);

            const bulgeFarX = moonX - radiusMoonEquatorial * Math.cos(thetaSpin);
            const bulgeFarY = moonY - radiusMoonEquatorial * Math.sin(thetaSpin);

            // Vector from planet to near bulge
            let dxNear = centerX - bulgeNearX;
            let dyNear = centerY - bulgeNearY;
            let distNear = Math.sqrt(dxNear*dxNear + dyNear*dyNear);

            // Vector from planet to far bulge
            let dxFar = centerX - bulgeFarX;
            let dyFar = centerY - bulgeFarY;
            let distFar = Math.sqrt(dxFar*dxFar + dyFar*dyFar);

            // Normalize vectors and apply inverse cube scaling for tidal force visual
            // Exaggerated for visualization to make arrows visible
            let forceScale = 50000000;

            let fNear = forceScale / (distNear * distNear * distNear);
            let nxNear = (dxNear / distNear) * fNear;
            let nyNear = (dyNear / distNear) * fNear;

            let fFar = forceScale / (distFar * distFar * distFar);
            let nxFar = (dxFar / distFar) * fFar;
            let nyFar = (dyFar / distFar) * fFar;

            // Draw force arrow on near bulge (stronger)
            drawArrow(ctx, bulgeNearX, bulgeNearY, bulgeNearX + nxNear, bulgeNearY + nyNear, 3, '#10b981'); // emerald

            // Draw force arrow on far bulge (weaker, pointing towards planet but visually we want to show the gradient stretching it outward relative to center)
            // To show the *differential* (tidal) force, the far bulge actually experiences a net force pushing it AWAY from the planet relative to the center.
            // Let's show the actual pull towards the planet to be physically accurate, but smaller.
            drawArrow(ctx, bulgeFarX, bulgeFarY, bulgeFarX + nxFar, bulgeFarY + nyFar, 2, '#34d399');

            // --- Update UI ---
            valOrbit.innerText = omegaOrbit.toFixed(4);
            valSpin.innerText = omegaSpin.toFixed(4);

            let phaseDeg = (physicsData.phaseLag * 180 / Math.PI);

            // Handle display of phase lag
            // Normalize for display so it oscillates around 0
            let displayPhase = phaseDeg;
            if (displayPhase > 90) displayPhase -= 180;
            if (displayPhase < -90) displayPhase += 180;

            valLag.innerText = displayPhase.toFixed(1);

            // Determine Status
            let spinDiff = Math.abs(omegaSpin - omegaOrbit);
            if (spinDiff < 0.0001 && Math.abs(displayPhase) < 1) {
              valStatus.innerText = "Tidally Locked";
            valStatus.className = "font-bold text-green-400";
            } else if (spinDiff < 0.01) {
              valStatus.innerText = "Damping (Libration)";
            valStatus.className = "font-bold text-yellow-400";
            } else {
              valStatus.innerText = "Rotating freely";
            valStatus.className = "font-bold text-white";
            }import React, {useState, useEffect, useRef} from 'react';

            // --- TRUE REAL-WORLD NORMALIZED PHYSICS ---
            // Unit of Mass: 1 Earth Mass
            // Unit of Distance: 1 Lunar Distance (384,400 km)
            // G is normalized to 1.
            const G = 1;
            const BASE_M_E = 1;
            const BASE_M_S = 333000; // Sun is 333,000x Earth's Mass
            const BASE_D_M = 1;      // Moon distance is 1 unit
            const BASE_D_E = 389;    // Earth distance from Sun is 389 Lunar Distances

            export default function App() {
  const [isPlaying, setIsPlaying] = useState(true);
            const [showVectors, setShowVectors] = useState(true);
            const [showApsidalLine, setShowApsidalLine] = useState(true);  const [activeForce, setActiveForce] = useState('all');
            const [simulationSpeed, setSimulationSpeed] = useState(5);

            // Controls multipliers
            const [sunGravityMult, setSunGravityMult] = useState(1);
            const [earthDistMult, setEarthDistMult] = useState(1);
            const [moonVelocityScale, setMoonVelocityScale] = useState(1);

            const [perturbationLevel, setPerturbationLevel] = useState("Nominal (Precessing)");
            const [moonSpeedDisplay, setMoonSpeedDisplay] = useState(0);

            const canvasRef = useRef(null);
            const animationRef = useRef(null);

            // Physics State Refs
            const isPlayingRef = useRef(isPlaying);
            const speedRef = useRef(simulationSpeed);
            const sunMultRef = useRef(sunGravityMult);
            const earthDistRef = useRef(earthDistMult);
            const moonVelScaleRef = useRef(moonVelocityScale);

            const timeRef = useRef(0);
            const moonRef = useRef({
              x: 0, y: 0, vx: 0, vy: 0, ax: 0, ay: 0,
            initialized: false,
            trail: [],
            prevDist: 0,
            apogee: null,
            perigee: null
  });

  // Sync React state to refs
  useEffect(() => {isPlayingRef.current = isPlaying; }, [isPlaying]);
  useEffect(() => {speedRef.current = simulationSpeed; }, [simulationSpeed]);
  useEffect(() => {sunMultRef.current = sunGravityMult; }, [sunGravityMult]);

  // Reset Moon if ANY physical dimensions change to prevent trailing mess
  useEffect(() => {
              moonRef.current.initialized = false;
            moonRef.current.trail = [];
            moonRef.current.apogee = null;
            moonRef.current.perigee = null;
  }, [earthDistMult, moonVelocityScale, sunGravityMult]);

  const resetSimulation = () => {
              moonRef.current.initialized = false;
            moonRef.current.trail = [];
            moonRef.current.apogee = null;    moonRef.current.perigee = null;
            timeRef.current = 0;
  };

  // Helper: Calculate forces using Hierarchical Reference Frame (Earth-centric)
  const getRelAccelerations = (x, y, t, R_E, M_S, w_earth) => {
    const X_E = R_E * Math.cos(w_earth * t);
            const Y_E = R_E * Math.sin(w_earth * t);

            const r_sq = x*x + y*y;
            const r_mag = Math.sqrt(r_sq);
            const safe_r_mag = Math.max(r_mag, 0.05); // Prevent div by zero
            const safe_r_sq = safe_r_mag * safe_r_mag;

            // Earth's pull on Moon (Relative)
            const a_E_x = - (G * BASE_M_E / safe_r_sq) * (x / safe_r_mag);
            const a_E_y = - (G * BASE_M_E / safe_r_sq) * (y / safe_r_mag);

            // Sun's pull on Moon (Requires absolute position)
            const M_sun_X = X_E + x;
            const M_sun_Y = Y_E + y;
            const d_sun_sq = M_sun_X*M_sun_X + M_sun_Y*M_sun_Y;
            const d_sun = Math.sqrt(d_sun_sq);
            const a_SM_x = - (G * M_S / d_sun_sq) * (M_sun_X / d_sun);
            const a_SM_y = - (G * M_S / d_sun_sq) * (M_sun_Y / d_sun);

            // Sun's pull on Earth
            const a_SE_x = - (G * M_S / (R_E*R_E)) * (X_E / R_E);
            const a_SE_y = - (G * M_S / (R_E*R_E)) * (Y_E / R_E);

            // Perturbing force = Force on Moon - Force on Earth
            const pert_x = a_SM_x - a_SE_x;
            const pert_y = a_SM_y - a_SE_y;

            return {
              ax: a_E_x + pert_x,
            ay: a_E_y + pert_y,
            pert_x: pert_x,
            pert_y: pert_y,
            r_mag: safe_r_mag 
    };
  };

  useEffect(() => {
    const canvas = canvasRef.current;
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const width = canvas.width;
            const height = canvas.height;
            const centerX = width / 2;
            const centerY = height / 2;

            // Visual rendering scales (Magnifying the Moon so it's visible)
            const renderScaleEarth = 220 / BASE_D_E; // Earth is drawn 220px from center
            const renderScaleMoon = 50 / BASE_D_M;   // Moon is drawn 50px from Earth

    const renderLoop = () => {
      if (!isPlayingRef.current) {
              animationRef.current = requestAnimationFrame(renderLoop);
            return;
      }

            const M_S = BASE_M_S * sunMultRef.current;
            const R_E = BASE_D_E * earthDistRef.current;
            const w_earth = Math.sqrt((G * M_S) / Math.pow(R_E, 3));

            const dt = 0.01;
            const substeps = 10;
            const step_dt = (dt * speedRef.current) / substeps;

            let currentEarthX, currentEarthY;
            let currentDistEarth = 1;
            let currentPertX = 0;
            let currentPertY = 0;

            // Physics Loop (Velocity Verlet Integrator strictly in Earth-Centric Frame)
            for (let i = 0; i < substeps; i++) {
        const t = timeRef.current;
            currentEarthX = R_E * Math.cos(w_earth * t);
            currentEarthY = R_E * Math.sin(w_earth * t);

            // Initialization (Relative coordinates: Earth is origin)
            if (!moonRef.current.initialized) {
              moonRef.current.x = BASE_D_M;
            moonRef.current.y = 0;

            const v_circ = Math.sqrt(G * BASE_M_E / BASE_D_M);
            moonRef.current.vx = 0;
            moonRef.current.vy = v_circ * moonVelScaleRef.current;

            const initialAcc = getRelAccelerations(moonRef.current.x, moonRef.current.y, t, R_E, M_S, w_earth);
            moonRef.current.ax = initialAcc.ax;
            moonRef.current.ay = initialAcc.ay;

            moonRef.current.initialized = true;
            moonRef.current.trail = [];
            moonRef.current.apogee = null;
            moonRef.current.perigee = null;
            moonRef.current.prevDist = BASE_D_M;
        }

            const m = moonRef.current;

            // Verlet Step 1: Advance Position
            m.x += m.vx * step_dt + 0.5 * m.ax * step_dt * step_dt;
            m.y += m.vy * step_dt + 0.5 * m.ay * step_dt * step_dt;

            // Advance Time for Earth
            timeRef.current += step_dt;
            const t_new = timeRef.current;
            const eX_new = R_E * Math.cos(w_earth * t_new);
            const eY_new = R_E * Math.sin(w_earth * t_new);

            // Verlet Step 2: Calculate New Forces
            const acc_new = getRelAccelerations(m.x, m.y, t_new, R_E, M_S, w_earth);
            currentDistEarth = acc_new.r_mag;
            currentPertX = acc_new.pert_x;
            currentPertY = acc_new.pert_y;

            // Verlet Step 3: Advance Velocity
            m.vx += 0.5 * (m.ax + acc_new.ax) * step_dt;
            m.vy += 0.5 * (m.ay + acc_new.ay) * step_dt;

            m.ax = acc_new.ax;
            m.ay = acc_new.ay;

            // Calculate continuous orbital elements (Eccentricity Vector)
            // Position relative to Earth
            const r_vec_x = m.x - eX_new;
            const r_vec_y = m.y - eY_new;

            // Velocity relative to Earth
            const v_eX = -R_E * w_earth * Math.sin(w_earth * t_new);
            const v_eY =  R_E * w_earth * Math.cos(w_earth * t_new);
            const v_vec_x = m.vx - v_eX;
            const v_vec_y = m.vy - v_eY;

            // Specific relative angular momentum (h = r x v)
            const h_z = r_vec_x * v_vec_y - r_vec_y * v_vec_x;

            // Eccentricity vector e = (v x h) / mu - (r / |r|)
            const mu = G * BASE_M_E;
            // v x h (2D cross product with Z-axis vector)
            const v_cross_h_x = v_vec_y * h_z;
            const v_cross_h_y = -v_vec_x * h_z;

            const e_vec_x = (v_cross_h_x / mu) - (r_vec_x / currentDistEarth);
            const e_vec_y = (v_cross_h_y / mu) - (r_vec_y / currentDistEarth);

            m.e_vec = {x: e_vec_x, y: e_vec_y };
      }

            // UI Update
            if (Math.random() < 0.1) {
        const speed = Math.sqrt(moonRef.current.vx*moonRef.current.vx + moonRef.current.vy*moonRef.current.vy);
            setMoonSpeedDisplay(speed.toFixed(3));

            // Calculate true perturbation ratio
            const earthPull = (G * BASE_M_E) / (currentDistEarth * currentDistEarth);
            const maxPerturbation = (2 * G * M_S * currentDistEarth) / Math.pow(R_E, 3);
            const ratio = maxPerturbation / earthPull;

            if (ratio < 0.05) setPerturbationLevel("Nominal (Stable Precession)");
            else if (ratio < 0.3) setPerturbationLevel("High (Heavy Warping)");
            else if (ratio < 0.7) setPerturbationLevel("Extreme (Chaotic)");
            else setPerturbationLevel("Ejected / Crashed");
      }

            const m = moonRef.current;
            m.trail.push({x: m.x, y: m.y });
      if (m.trail.length > 120) m.trail.shift();

            // --- RENDERING ---
            ctx.clearRect(0, 0, width, height);

            // Render Sun
            ctx.beginPath();
            const sunRadius = Math.max(25 * Math.sqrt(sunMultRef.current), 10);
