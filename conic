<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Conic Sections</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #0b0c10;
            color: #c5c6c7;
            font-family: 'Inter', sans-serif;
        }

        #canvas-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
        }

        .glass-panel {
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            z-index: 10;
        }

        /* Custom Slider Styling */
        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: transparent;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 20px;
            width: 20px;
            border-radius: 50%;
            background: #ffffff;
            cursor: pointer;
            margin-top: -8px;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
            transition: transform 0.1s;
        }

        input[type=range]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }

        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 4px;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
        }
    </style>
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>
</head>

<body class="antialiased selection:bg-cyan-500 selection:text-white">

    <div id="canvas-container"></div>

    <!-- UI Panel -->
    <div class="glass-panel absolute top-6 left-6 p-6 rounded-2xl w-96 max-h-[90vh] overflow-y-auto">
        <h1 class="text-2xl font-extrabold text-white mb-2 tracking-tight">
            Conic Sections
        </h1>
        <p class="text-sm text-slate-400 mb-4 leading-relaxed">
            Adjust the angle of the intersecting plane to discover how slicing a 3D cone generates the four fundamental
            2D curves.
        </p>

        <!-- The Slider Control -->
        <div class="mb-6 p-4 rounded-xl bg-slate-800/50 border border-slate-700">
            <label for="angleSlider"
                class="flex justify-between text-sm font-bold text-cyan-400 mb-4 uppercase tracking-wide">
                <span>Plane Angle (θ)</span>
                <span id="angleValue" class="text-white">0°</span>
            </label>
            <input type="range" id="angleSlider" min="0" max="80" value="0" step="1">
            <div class="flex justify-between text-xs text-slate-500 mt-2 font-mono">
                <span>0° (Flat)</span>
                <span>45° (Wall)</span>
                <span>80° (Steep)</span>
            </div>
        </div>

        <!-- Live Eccentricity Math -->
        <div class="mb-6 p-4 rounded-xl bg-slate-800/80 border border-teal-500/30">
            <h2 class="text-xs text-teal-400 font-bold uppercase tracking-wider mb-2">Orbital Eccentricity (e)</h2>
            <p class="text-xs text-slate-300 mb-3 leading-relaxed">
                If the cone slope is β (here β = 45°) and the plane tilt is θ, the eccentricity is purely defined by
                their ratio:
                <span class="block text-center font-mono text-white bg-slate-900 rounded p-1 mt-1">e = sin(θ) /
                    sin(β)</span>
            </p>
            <div class="flex justify-between items-center border-t border-slate-700/50 pt-2 font-mono">
                <span class="text-sm text-slate-400">Current <i>e</i>:</span>
                <span id="eccentricityValue" class="text-lg font-bold text-white">0.000</span>
            </div>
        </div>

        <!-- Live Math Classification -->
        <div class="space-y-4">
            <h2 class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-2">Geometric Classification</h2>

            <div id="class-circle"
                class="p-3 rounded-lg border border-red-500/30 bg-red-500/10 transition-all duration-300">
                <div class="flex items-center justify-between mb-1">
                    <span class="font-bold text-red-400 text-lg">Circle</span>
                    <span class="text-xs font-mono bg-red-500/20 text-red-300 px-2 py-1 rounded">e = 0</span>
                </div>
                <p class="text-xs text-slate-300">Plane Angle = 0°. The intersection is equidistant from the cone's
                    central axis.</p>
            </div>

            <div id="class-ellipse"
                class="p-3 rounded-lg border border-transparent opacity-40 transition-all duration-300">
                <div class="flex items-center justify-between mb-1">
                    <span class="font-bold text-green-400 text-lg">Ellipse</span>
                    <span class="text-xs font-mono bg-green-500/20 text-green-300 px-2 py-1 rounded">0 < e < 1</span>
                </div>
                <p class="text-xs text-slate-300">Angle < 45°. The plane is shallower than the cone's wall. It cuts
                        entirely across to form a closed loop.</p>
            </div>

            <div id="class-parabola"
                class="p-3 rounded-lg border border-transparent opacity-40 transition-all duration-300">
                <div class="flex items-center justify-between mb-1">
                    <span class="font-bold text-blue-400 text-lg">Parabola</span>
                    <span class="text-xs font-mono bg-blue-500/20 text-blue-300 px-2 py-1 rounded">e = 1</span>
                </div>
                <p class="text-xs text-slate-300">Angle = 45°. The plane is perfectly parallel to one side of the cone.
                    The curve opens up.</p>
            </div>

            <div id="class-hyperbola"
                class="p-3 rounded-lg border border-transparent opacity-40 transition-all duration-300">
                <div class="flex items-center justify-between mb-1">
                    <span class="font-bold text-orange-400 text-lg">Hyperbola</span>
                    <span class="text-xs font-mono bg-orange-500/20 text-orange-300 px-2 py-1 rounded">e > 1</span>
                </div>
                <p class="text-xs text-slate-300">Angle > 45°. The plane is steeper than the cone's wall, forming an
                    open, unbounded curve.</p>
            </div>
        </div>
    </div>

    <!-- Legend Panel -->
    <div class="glass-panel absolute top-6 right-6 p-4 rounded-xl text-xs space-y-2 pointer-events-none">
        <div class="flex items-center">
            <div class="w-3 h-3 border border-slate-400 mr-2 rounded-sm bg-white/5"></div> Cone (Slope = 45°)
        </div>
        <div class="flex items-center">
            <div class="w-3 h-3 bg-white/30 mr-2 rounded-sm"></div> Slicing Plane
        </div>
        <div class="flex items-center">
            <div class="w-3 h-3 bg-current mr-2 rounded-full" id="legend-color-dot" style="color: #ef4444;"></div>
            Intersection Curve
        </div>
    </div>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // --- 1. Scene Setup ---
        const container = document.getElementById('canvas-container');
        const scene = new THREE.Scene();

        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(60, 20, 60);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.target.set(0, -20, 0); // Target center of the cone

        // Lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);
        const dirLight = new THREE.DirectionalLight(0xffffff, 1.0);
        dirLight.position.set(50, 80, 30);
        scene.add(dirLight);

        // --- 2. Static Geometry (The Cone) ---
        const coneSlopeAngle = Math.PI / 4; // 45 degrees
        const coneHeight = 60;
        const coneRadius = coneHeight * Math.tan(coneSlopeAngle); // Also 60 for 45 deg

        const coneGroup = new THREE.Group();
        scene.add(coneGroup);

        // Solid transparent downward cone (apex at origin)
        const coneGeo = new THREE.ConeGeometry(coneRadius, coneHeight, 64, 1, true);
        coneGeo.translate(0, -coneHeight / 2, 0);

        const coneMat = new THREE.MeshPhysicalMaterial({
            color: 0xffffff, transparent: true, opacity: 0.1,
            side: THREE.DoubleSide, depthWrite: false, roughness: 0.2
        });
        const coneMesh = new THREE.Mesh(coneGeo, coneMat);
        coneGroup.add(coneMesh);

        // Cone Wireframe Edges (diagram look)
        const edgeGeo = new THREE.ConeGeometry(coneRadius, coneHeight, 16, 1, true);
        edgeGeo.translate(0, -coneHeight / 2, 0);
        const edges = new THREE.EdgesGeometry(edgeGeo);
        const edgeMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.15 });
        const coneEdges = new THREE.LineSegments(edges, edgeMat);
        coneGroup.add(coneEdges);

        // Central Axis Line
        const axisGeo = new THREE.BufferGeometry().setFromPoints([
            new THREE.Vector3(0, 10, 0),
            new THREE.Vector3(0, -coneHeight - 10, 0)
        ]);
        const axisMat = new THREE.LineDashedMaterial({ color: 0xffffff, dashSize: 1, gapSize: 1, transparent: true, opacity: 0.4 });
        const axisLine = new THREE.Line(axisGeo, axisMat);
        axisLine.computeLineDistances();
        coneGroup.add(axisLine);

        // --- 3. Dynamic Geometry (Plane and Intersection) ---
        const dynamicGroup = new THREE.Group();
        scene.add(dynamicGroup);

        // 3a. Slicing Plane
        const planeGeo = new THREE.PlaneGeometry(120, 160);
        planeGeo.rotateX(-Math.PI / 2); // Lay flat initially
        const planeMat = new THREE.MeshPhysicalMaterial({
            color: 0xffffff, transparent: true, opacity: 0.2,
            side: THREE.DoubleSide, depthWrite: false
        });
        const planeMesh = new THREE.Mesh(planeGeo, planeMat);

        // Pivot group to tilt the plane. 
        const pivotY = -25;
        const planePivot = new THREE.Group();
        planePivot.position.y = pivotY;
        planePivot.add(planeMesh);
        dynamicGroup.add(planePivot);

        // 3b. Intersection Curve Line
        const curveMat = new THREE.LineBasicMaterial({ color: 0xef4444, linewidth: 4 });
        const curveLine = new THREE.Line(new THREE.BufferGeometry(), curveMat);
        dynamicGroup.add(curveLine);

        // 3c. Intersection Filled Surface
        const surfaceMat = new THREE.MeshBasicMaterial({ color: 0xef4444, transparent: true, opacity: 0.4, side: THREE.DoubleSide, depthWrite: false });
        const surfaceMesh = new THREE.Mesh(new THREE.BufferGeometry(), surfaceMat);
        dynamicGroup.add(surfaceMesh);


        // --- 4. Mathematical Intersection Logic ---

        // Colors mapping from Wikipedia
        const colors = {
            circle: 0xef4444,    // Red
            ellipse: 0x4ade80,   // Green
            parabola: 0x60a5fa,  // Blue
            hyperbola: 0xf97316  // Orange
        };

        const uiElements = {
            circle: document.getElementById('class-circle'),
            ellipse: document.getElementById('class-ellipse'),
            parabola: document.getElementById('class-parabola'),
            hyperbola: document.getElementById('class-hyperbola')
        };

        function updateUIState(type, colorHex) {
            // Update UI Highlighting
            Object.keys(uiElements).forEach(key => {
                const el = uiElements[key];
                if (key === type) {
                    el.classList.remove('opacity-40', 'border-transparent');
                    // Inject dynamic tailwind border/bg based on color 
                    if (type === 'circle') el.style = 'border-color: rgba(239, 68, 68, 0.3); background-color: rgba(239, 68, 68, 0.1);';
                    if (type === 'ellipse') el.style = 'border-color: rgba(74, 222, 128, 0.3); background-color: rgba(74, 222, 128, 0.1);';
                    if (type === 'parabola') el.style = 'border-color: rgba(96, 165, 250, 0.3); background-color: rgba(96, 165, 250, 0.1);';
                    if (type === 'hyperbola') el.style = 'border-color: rgba(249, 115, 22, 0.3); background-color: rgba(249, 115, 22, 0.1);';
                } else {
                    el.classList.add('opacity-40', 'border-transparent');
                    el.style = '';
                }
            });

            // Update 3D Colors
            curveMat.color.setHex(colorHex);
            surfaceMat.color.setHex(colorHex);
            document.getElementById('legend-color-dot').style.color = '#' + colorHex.toString(16).padStart(6, '0');
        }

        function calculateIntersection(angleDeg) {
            const angleRad = THREE.MathUtils.degToRad(angleDeg);

            // 1. Tilt the plane
            planePivot.rotation.z = angleRad; // Tilt around Z axis

            // 2. Identify the shape and set colors
            let shapeType = '';
            let shapeColor = 0;

            if (angleDeg === 0) {
                shapeType = 'circle'; shapeColor = colors.circle;
            } else if (angleDeg < 45) {
                shapeType = 'ellipse'; shapeColor = colors.ellipse;
            } else if (angleDeg === 45) {
                shapeType = 'parabola'; shapeColor = colors.parabola;
            } else {
                shapeType = 'hyperbola'; shapeColor = colors.hyperbola;
            }

            updateUIState(shapeType, shapeColor);

            // MATH: Calculate Eccentricity
            // Formula: e = sin(theta) / sin(beta)
            // Where theta = angle of the plane, beta = angle of the cone slope
            // In our model, beta = 45 deg, so sin(45) = sqrt(2)/2 = 0.7071
            const e = Math.sin(angleRad) / Math.sin(Math.PI / 4);
            document.getElementById('eccentricityValue').textContent = e.toFixed(3);


            // 3. Generate intersection points
            const points = [];
            const m = Math.tan(angleRad); // Positive mathematical slope maps perfectly to rotation
            const c = pivotY;    // y-intercept (negative)

            if (angleDeg < 45) {
                // Ellipse / Circle
                const denom = 1 - m * m;
                // FIXED: Removed the erroneous negative sign to shift center to the wider side
                const centerX = (m * c) / denom;
                const semiAxisX = Math.sqrt((c * c) / (denom * denom));
                const semiAxisZ = Math.sqrt((c * c) / denom);

                for (let i = 0; i <= 64; i++) {
                    const t = (i / 64) * Math.PI * 2;
                    const dx = semiAxisX * Math.cos(t);
                    const z = semiAxisZ * Math.sin(t);
                    const x = centerX + dx;
                    const y = m * x + c;
                    points.push(new THREE.Vector3(x, y, z));
                }
            }
            else if (angleDeg === 45) {
                // Parabola (m = 1)
                const zLimit = 40;
                for (let i = 0; i <= 64; i++) {
                    const z = -zLimit + (i / 64) * (2 * zLimit);
                    // FIXED: Removed the erroneous negative sign to align with the plane
                    const x = (z * z - c * c) / (2 * c);
                    const y = m * x + c;

                    if (y >= -coneHeight) {
                        points.push(new THREE.Vector3(x, y, z));
                    }
                }
            }
            else {
                // Hyperbola
                const denom = m * m - 1;
                // FIXED: Added the necessary negative sign to bring the hyperbola back up onto the cone
                const centerX = -(m * c) / denom;
                const semiAxisX = Math.sqrt((c * c) / (denom * denom));
                const semiAxisZ = Math.sqrt((c * c) / denom);

                const tLimit = 1.2;
                for (let i = 0; i <= 64; i++) {
                    const t = -tLimit + (i / 64) * (2 * tLimit);
                    const dx = semiAxisX / Math.cos(t);
                    const z = semiAxisZ * Math.tan(t);

                    // Branch mapping: For downward cone, select the branch that falls in y <= 0
                    const x = centerX - dx;
                    const y = m * x + c;

                    if (y >= -coneHeight && y <= 0) {
                        points.push(new THREE.Vector3(x, y, z));
                    }
                }
            }

            // Update Line Geometry
            curveLine.geometry.setFromPoints(points);

            // Update Filled Surface Geometry
            if (points.length > 2) {
                const vertices = [];
                let cx = 0, cy = 0, cz = 0;
                for (let p of points) { cx += p.x; cy += p.y; cz += p.z; }
                cx /= points.length; cy /= points.length; cz /= points.length;

                for (let i = 0; i < points.length - 1; i++) {
                    vertices.push(cx, cy, cz);
                    vertices.push(points[i].x, points[i].y, points[i].z);
                    vertices.push(points[i + 1].x, points[i + 1].y, points[i + 1].z);
                }

                if (angleDeg < 45) {
                    vertices.push(cx, cy, cz);
                    vertices.push(points[points.length - 1].x, points[points.length - 1].y, points[points.length - 1].z);
                    vertices.push(points[0].x, points[0].y, points[0].z);
                }

                surfaceMesh.geometry.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
                surfaceMesh.geometry.computeVertexNormals();
            } else {
                surfaceMesh.geometry.setAttribute('position', new THREE.Float32BufferAttribute([], 3));
            }
        }

        // --- 5. UI Event Listeners ---
        const angleSlider = document.getElementById('angleSlider');
        const angleValueDisplay = document.getElementById('angleValue');

        angleSlider.addEventListener('input', (e) => {
            const deg = parseInt(e.target.value);
            angleValueDisplay.textContent = deg + '°';
            calculateIntersection(deg);
        });

        // Initialize scene
        calculateIntersection(0);

        // --- 6. Render Loop ---
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }

        // Start animation immediately
        animate();
    </script>
</body>

</html>